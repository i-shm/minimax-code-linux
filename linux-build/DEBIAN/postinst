#!/bin/bash
set -e

case "$1" in
    configure)
        # ── Desktop integration ──
        if [ -x /usr/bin/update-desktop-database ]; then
            /usr/bin/update-desktop-database /usr/share/applications/ 2>/dev/null || true
        fi
        if [ -x /usr/bin/gtk-update-icon-cache ]; then
            /usr/bin/gtk-update-icon-cache /usr/share/icons/hicolor 2>/dev/null || true
        fi

        # ── Permissions ──
        if [ -f /opt/minimax-agent/chrome-sandbox ]; then
            chmod 4755 /opt/minimax-agent/chrome-sandbox 2>/dev/null || true
        fi
        if [ -d /opt/minimax-agent/resources/resources/opencode ]; then
            find /opt/minimax-agent/resources/resources/opencode -type f -exec chmod 755 {} \; 2>/dev/null || true
        fi

        # ── OAuth protocol handlers ──
        if command -v xdg-mime >/dev/null 2>&1; then
            xdg-mime default minimax-agent.desktop x-scheme-handler/minimax 2>/dev/null || true
            xdg-mime default minimax-agent.desktop x-scheme-handler/minimax-agent 2>/dev/null || true
        fi
        if command -v gio >/dev/null 2>&1; then
            gio mime x-scheme-handler/minimax minimax-agent.desktop 2>/dev/null || true
            gio mime x-scheme-handler/minimax-agent minimax-agent.desktop 2>/dev/null || true
        fi

        # ── Backend daemon setup ──
        DAEMON_DIR="/opt/minimax-agent/resources/resources/daemon"
        if command -v node >/dev/null 2>&1; then
            NODE_VER=$(node --version)
            echo "minimax-agent: Node.js $NODE_VER detected."

            # Verify native daemon modules and rebuild if needed
            if [ -d "$DAEMON_DIR/node_modules" ]; then
                NEED_REBUILD=false
                node -e "require('better-sqlite3')" 2>/dev/null || NEED_REBUILD=true
                node -e "require('fs-native-extensions')" 2>/dev/null || NEED_REBUILD=true
                if $NEED_REBUILD && command -v npm >/dev/null 2>&1; then
                    echo "minimax-agent: Rebuilding native modules for $NODE_VER..."
                    cd "$DAEMON_DIR" && npm rebuild 2>&1 && \
                        echo "minimax-agent: Native modules rebuilt." || \
                        echo "minimax-agent: WARNING - npm rebuild failed. Run manually: cd $DAEMON_DIR && npm rebuild"
                fi
            fi
        else
            echo "WARNING: minimax-agent -- Node.js not found."
            echo "  The backend daemon requires Node.js >= 18."
            echo "  Install it: sudo apt install nodejs"
            echo "  Or use nvm: https://github.com/nvm-sh/nvm"
        fi

        # Prepare backend daemon directories for every human user
        SYSTEMD_ACTIVE=false
        if command -v loginctl >/dev/null 2>&1 && command -v systemctl >/dev/null 2>&1 && [ "$(ps -p 1 -o comm= 2>/dev/null)" = "systemd" ]; then
            SYSTEMD_ACTIVE=true
        fi

        for entry in $(getent passwd 2>/dev/null | awk -F: '$3 >= 1000 && $3 < 65534 && $7 !~ /nologin|false/ {print $1":"$6}'); do
            user="${entry%%:*}"
            home="${entry#*:}"
            if [ -z "$user" ] || [ "$user" = "root" ]; then
                continue
            fi

            # Enable linger so systemctl --user works after logout
            if $SYSTEMD_ACTIVE; then
                loginctl enable-linger "$user" 2>/dev/null || true
            fi

            # Handle broken symlink at ~/.mavis (from previous installations)
            if [ -L "$home/.mavis" ] && [ ! -e "$home/.mavis" ]; then
                rm -f "$home/.mavis" 2>/dev/null || true
            fi

            # Pre-create daemon directories
            mkdir -p "$home/.mavis/logs" 2>/dev/null || true
            mkdir -p "$home/.mavis/screenshots" 2>/dev/null || true

            # Fix ownership if we created dirs as root
            chown "$user:$user" "$home/.mavis" 2>/dev/null || true
            chown -R "$user:$user" "$home/.mavis/logs" "$home/.mavis/screenshots" 2>/dev/null || true
        done
        ;;
esac

exit 0
